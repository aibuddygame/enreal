{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/work/(.*)",
      "dest": "/work/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/ai-(.+)\\.(jpg|png|jpeg|webp)",
      "dest": "/ai-$1.$2"
    },
    {
      "src": "/hero-cover\\.png",
      "dest": "/hero-cover.png"
    },
    {
      "src": "/og-(.+)\\.(jpg|png)",
      "dest": "/og-$1.$2"
    },
    {
      "src": "/manifest\\.webmanifest",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "/sw\\.js",
      "dest": "/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
